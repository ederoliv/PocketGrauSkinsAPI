# PostgreSQL Railway
DATABASE_URL=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=     # ex: https://pub-xxxx.r2.dev

# Auth do painel admin
# Gerar o hash localmente com:
#   node -e "const b=require('bcrypt'); b.hash('sua-senha',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Chave secreta para assinar os JWT (qualquer string longa e aleatória)
JWT_SECRET=

# Porta local (opcional, padrão 3000)
PORT=3000
